<UserControl x:Class="DnDCharacterManager.Desktop.Views.CharactersListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Созданные персонажи" Style="{StaticResource FantasyPageTitle}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="280" Margin="0,0,8,0"
                     materialDesign:HintAssist.Hint="Поиск по имени" />
            <Button Content="Обновить" Command="{Binding LoadCharactersCommand}"
                    Style="{StaticResource FantasyRaisedButton}" />
        </StackPanel>

        <DataGrid Grid.Row="2"
                  RowHeight="52"
                  ItemsSource="{Binding Characters}"
                  SelectedItem="{Binding SelectedCharacter}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Background="{StaticResource FantasySurfaceBrush}"
                  Foreground="{StaticResource FantasyTextBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Уровень" Binding="{Binding Level}" Width="80" />
                <DataGridTextColumn Header="Раса" Binding="{Binding RaceName}" Width="120" />
                <DataGridTextColumn Header="Класс" Binding="{Binding ClassName}" Width="120" />
                <DataGridTextColumn Header="Обновлён" Binding="{Binding UpdatedAt, StringFormat=dd.MM.yyyy}" Width="100" />
                <DataGridTemplateColumn Header="Действия" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Открыть"
                                        Command="{Binding DataContext.OpenCharacterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FantasyFlatButton}" />
                                <Button Content="Удалить"
                                        Command="{Binding DataContext.DeleteCharacterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FantasyFlatButton}"
                                        Foreground="IndianRed" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
    </Grid>
</UserControl>
