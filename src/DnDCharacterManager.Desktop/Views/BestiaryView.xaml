<UserControl x:Class="DnDCharacterManager.Desktop.Views.BestiaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Бестиарий" Style="{StaticResource FantasyPageTitle}" />

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="240" Margin="0,0,8,0"
                     materialDesign:HintAssist.Hint="Поиск монстра" />
            <ComboBox ItemsSource="{Binding CreatureTypes}"
                      SelectedItem="{Binding SelectedCreatureType}"
                      Width="180" Margin="0,0,8,0"
                      materialDesign:HintAssist.Hint="Тип существа" />
            <ComboBox ItemsSource="{Binding SortOptions}"
                      SelectedItem="{Binding SelectedSort}"
                      Width="140" Margin="0,0,8,0"
                      materialDesign:HintAssist.Hint="Сортировка" />
            <Button Content="Найти" Command="{Binding SearchCommand}"
                    Style="{StaticResource FantasyRaisedButton}" />
        </StackPanel>

        <ListBox Grid.Row="2" Grid.Column="0"
                 ItemsSource="{Binding Monsters}"
                 SelectedItem="{Binding SelectedMonster}"
                 DisplayMemberPath="Name"
                 Margin="0,0,8,0" />

        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource FantasyCardBorder}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel DataContext="{Binding SelectedMonster}">
                    <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource FantasyAccentBrush}" />
                    <TextBlock Margin="0,8">
                        <Run Text="КО: " /><Run Text="{Binding ChallengeRating}" />
                        <Run Text="  |  КБ: " /><Run Text="{Binding ArmorClass}" />
                        <Run Text="  |  ХП: " /><Run Text="{Binding HitPoints}" />
                    </TextBlock>
                    <TextBlock Text="{Binding CreatureType}" Margin="0,4"
                               Foreground="{StaticResource FantasyTextMutedBrush}" />
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,12,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <ProgressBar Grid.Row="2" Grid.ColumnSpan="2" IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
    </Grid>
</UserControl>
