<UserControl x:Class="DnDCharacterManager.Desktop.Views.CharacterCreatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:DnDCharacterManager.Desktop.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Создание персонажа" Style="{StaticResource FantasyPageTitle}" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="{Binding StepTitle}" FontSize="18" Foreground="{StaticResource FantasyAccentBrush}" />
            <TextBlock Text="{Binding CurrentStepDisplay}" Margin="16,0,0,0"
                       Foreground="{StaticResource FantasyTextMutedBrush}" VerticalAlignment="Center" />
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Races}" ItemTemplate="{StaticResource SelectionCardTemplate}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:CreatorStep.Race}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding Classes}" ItemTemplate="{StaticResource SelectionCardTemplate}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:CreatorStep.Class}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding Backgrounds}" ItemTemplate="{StaticResource SelectionCardTemplate}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:CreatorStep.Background}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding Traits}" ItemTemplate="{StaticResource SelectionCardTemplate}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:CreatorStep.Traits}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding Spells}" ItemTemplate="{StaticResource SelectionCardTemplate}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:CreatorStep.Spells}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:CreatorStep.Equipment}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox Text="{Binding NewEquipmentItem, UpdateSourceTrigger=PropertyChanged}"
                                 Width="300" Margin="0,0,8,0"
                                 materialDesign:HintAssist.Hint="Название предмета" />
                        <Button Content="Добавить" Command="{Binding AddEquipmentCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding EquipmentItems}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="✕"
                                            Command="{Binding DataContext.RemoveEquipmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconButton}" />
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:CreatorStep.Abilities}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Content="Стандартный массив" Command="{Binding ApplyStandardArrayCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding AbilityEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{Binding DisplayName}" Width="120" VerticalAlignment="Center" />
                                    <Slider Value="{Binding Score}" Minimum="3" Maximum="18" Width="200"
                                            TickFrequency="1" IsSnapToTickEnabled="True" />
                                    <TextBlock Text="{Binding Score}" Width="30" Margin="8,0" VerticalAlignment="Center" />
                                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource FantasyTextMutedBrush}">
                                        <Run Text="(" /><Run Text="{Binding Modifier, StringFormat={}{0:+0;-0;0}}" /><Run Text=")" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:CreatorStep.Alignment}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ComboBox ItemsSource="{Binding Alignments}"
                              SelectedItem="{Binding SelectedAlignment}"
                              Width="300" Margin="0,0,0,12" />
                    <TextBox Text="{Binding CharacterName, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Имя персонажа" Width="300" />
                </StackPanel>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:CreatorStep.Portrait}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Content="Выбрать портрет" Command="{Binding BrowsePortraitCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,12" />
                    <TextBlock Text="{Binding PortraitPath}" Foreground="{StaticResource FantasyTextMutedBrush}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Назад" Command="{Binding PreviousStepCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0" />
            <Button Command="{Binding NextStepCommand}" Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                        <Setter Property="Content" Value="Далее" />
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:CreatorStep.Portrait}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Command="{Binding SaveCharacterCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                        <Setter Property="Content" Value="Создать персонажа" />
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:CreatorStep.Portrait}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <ProgressBar Grid.RowSpan="4" IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                     VerticalAlignment="Top" Height="4" />
    </Grid>
</UserControl>
