<UserControl x:Class="DnDCharacterManager.Desktop.Views.RulebookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Правила" Style="{StaticResource FantasyPageTitle}" />

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="240" Margin="0,0,8,0"
                     materialDesign:HintAssist.Hint="Поиск правил" />
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Width="180" Margin="0,0,8,0"
                      materialDesign:HintAssist.Hint="Категория" />
            <Button Content="Найти" Command="{Binding SearchCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>

        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource FantasyCardBorder}" Margin="0,0,8,0">
            <StackPanel>
                <TextBlock Text="Глоссарий" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{StaticResource FantasyAccentBrush}" />
                <ListBox ItemsSource="{Binding GlossaryTerms}" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Term}"
                                    Command="{Binding DataContext.SelectGlossaryTermCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalContentAlignment="Left" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <ListBox Grid.Row="0" ItemsSource="{Binding Rules}"
                     SelectedItem="{Binding SelectedRule}"
                     DisplayMemberPath="Title" Margin="0,0,0,8" />

            <Border Grid.Row="1" Style="{StaticResource FantasyCardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedRule.Title}" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource FantasyAccentBrush}" />
                        <TextBlock Text="{Binding SelectedRule.Source}" Margin="0,4"
                                   Foreground="{StaticResource FantasyTextMutedBrush}" />

                        <ItemsControl ItemsSource="{Binding RuleContentSegments}" Margin="0,12,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl>
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="Content">
                                                    <Setter.Value>
                                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLinkedTerm}" Value="True">
                                                        <Setter Property="Content">
                                                            <Setter.Value>
                                                                <Button Content="{Binding Text}"
                                                                        Command="{Binding DataContext.OpenLinkedTermCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding LinkedTerm}"
                                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                                        Padding="0" Margin="0"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="{StaticResource FantasyAccentBrush}" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <ProgressBar Grid.Row="2" Grid.ColumnSpan="2" IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
    </Grid>
</UserControl>
