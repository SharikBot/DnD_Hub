<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Dark fantasy palette: deep brown, bronze, gold, parchment -->
    <Color x:Key="FantasyBackgroundDark">#FF1A1208</Color>
    <Color x:Key="FantasyBackgroundMid">#FF2D1F0F</Color>
    <Color x:Key="FantasySurface">#FF3D2B16</Color>
    <Color x:Key="FantasyBronze">#FFB8860B</Color>
    <Color x:Key="FantasyGold">#FFC9A227</Color>
    <Color x:Key="FantasyGoldLight">#FFE8C547</Color>
    <Color x:Key="FantasyParchment">#FFF4E4BC</Color>
    <Color x:Key="FantasyParchmentDim">#FFD4C49C</Color>
    <Color x:Key="FantasyTextPrimary">#FFF4E4BC</Color>
    <Color x:Key="FantasyTextSecondary">#FFB8A88A</Color>

    <SolidColorBrush x:Key="FantasyBackgroundBrush" Color="{StaticResource FantasyBackgroundDark}" />
    <SolidColorBrush x:Key="FantasySurfaceBrush" Color="{StaticResource FantasySurface}" />
    <SolidColorBrush x:Key="FantasySidebarBrush" Color="{StaticResource FantasyBackgroundMid}" />
    <SolidColorBrush x:Key="FantasyAccentBrush" Color="{StaticResource FantasyGold}" />
    <SolidColorBrush x:Key="FantasyAccentLightBrush" Color="{StaticResource FantasyGoldLight}" />
    <SolidColorBrush x:Key="FantasyBronzeBrush" Color="{StaticResource FantasyBronze}" />
    <SolidColorBrush x:Key="FantasyParchmentBrush" Color="{StaticResource FantasyParchment}" />
    <SolidColorBrush x:Key="FantasyTextBrush" Color="{StaticResource FantasyTextPrimary}" />
    <SolidColorBrush x:Key="FantasyTextMutedBrush" Color="{StaticResource FantasyTextSecondary}" />

    <Style x:Key="FantasyPageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource FantasyAccentLightBrush}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="FantasySubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource FantasyTextMutedBrush}" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="FantasyCardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FantasySurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FantasyBronzeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="4" />
    </Style>

    <!-- Кнопки: увеличенные отступы и MinHeight, чтобы текст и тень не обрезались -->
    <Style x:Key="FantasyRaisedButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
    </Style>

    <Style x:Key="FantasyOutlinedButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
    </Style>

    <Style x:Key="FantasyFlatButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0" />
    </Style>

    <Style x:Key="FantasyIconButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="FantasySidebarButton" TargetType="Button" BasedOn="{StaticResource FantasyFlatButton}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="4,2" />
        <Setter Property="Foreground" Value="{StaticResource FantasyParchmentBrush}" />
    </Style>

    <!-- Карточки выбора в мастере создания — без фиксированной высоты кнопки -->
    <Style x:Key="FantasySelectionCardButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

</ResourceDictionary>
