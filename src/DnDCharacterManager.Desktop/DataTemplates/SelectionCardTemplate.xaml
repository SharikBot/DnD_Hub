<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:DnDCharacterManager.Desktop.Models"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <DataTemplate x:Key="SelectionCardTemplate" DataType="{x:Type models:SelectionCardItem}">
        <Button Command="{Binding DataContext.SelectCardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"
                Style="{StaticResource FantasySelectionCardButton}">
            <Border Background="{StaticResource FantasySurfaceBrush}"
                    BorderBrush="{StaticResource FantasyBronzeBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="4"
                    Width="220"
                    MinHeight="140">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource FantasySurfaceBrush}" />
                        <Setter Property="BorderBrush" Value="{StaticResource FantasyBronzeBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource FantasyAccentLightBrush}" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{Binding Name}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FantasyAccentBrush}" />
                    <TextBlock Text="{Binding Subtitle}"
                               FontSize="12"
                               Foreground="{StaticResource FantasyTextMutedBrush}"
                               Margin="0,4,0,8" />
                    <TextBlock Text="{Binding Description}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource FantasyTextBrush}"
                               MaxHeight="80"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </Button>
    </DataTemplate>

</ResourceDictionary>
